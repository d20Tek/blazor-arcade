@page "/accounts/manage"
@attribute [Authorize]
@inject ILocalStorageService _storage
@inject ICrudClientService<UserAccount> _service
@inject IMessageBoxService _msgbox

<div class="row justify-content-center">
  <div class="col-12 col-lg-6" style="max-width: 600px">
    <h4>Manage Accounts</h4>
    <div style="font-weight: bold">Current Account:</div>
    @if (_currentAccount != null)
    {
      <div class="float-end">
        <div>Avatar:</div>
        <img class="border" width="64" src="/images/coming-soon.png" />
      </div>
      <div>Id: @_currentAccount.Id</div>
      <div>Name: @_currentAccount.Name</div>
      <div>Server: @_currentAccount.Server</div>
      <div>Gender: @_currentAccount.Gender</div>
      <div class="mt-2">
        <a id="edit-account-btn" class="btn btn-outline-light" href=@EditAccountUrl>
          Edit Account Info
        </a>
        <button id="delete-account-btn" class="btn btn-outline-light"
                @onclick=OnAccountDelete>
          Delete This Account
        </button>
      </div>
    }
    else
    {
      <div>No account selected, pick one below.</div>
    }
    <hr />

    <AccountPicker CurrentUserAccount=@_currentAccount
                   UserAccounts=@_userAccounts
                   SelectedAccountChanged=@OnAccountChanged/>

    <a id="create-account-btn" class="btn btn-outline-light" href="/account/create">
      Create New Account
    </a>
  </div>
</div>

@code {
    private string _accountKey = string.Empty;
    private UserAccount? _currentAccount;
    private IList<UserAccount>? _userAccounts;

    internal string EditAccountUrl => $"/account/update/{_currentAccount?.Id}";

    [CascadingParameter]
    public Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _accountKey = await Constants.GetUserAccountKey(AuthState);
        _currentAccount = await _storage.GetItemAsync<UserAccount>(_accountKey);

        _userAccounts = await _service.GetEntitiesAsync();
        if (_userAccounts?.Any(p => p.Id == _currentAccount?.Id) == false)
        {
            await ClearAccountFromStorage();
        }
    }

    private async Task OnAccountChanged(UserAccount account)
    {
        _currentAccount = account;
        await _storage.SetItemAsync(_accountKey, account);
    }

    private async Task OnAccountDelete()
    {
        if (_currentAccount != null)
        {
            var confirmed = await _msgbox.Confirm("Are you sure you want to permanently delete this account? \r\nYou will not be able to recover it later.");
            if (confirmed == true)
            {
                await _service.DeleteEntityAsync(_currentAccount.Id);
                await ClearAccountFromStorage();
            }
        }
    }

    private async Task ClearAccountFromStorage()
    {
        await _storage.RemoveItemAsync(_accountKey);
        _currentAccount = null;
    }
}
