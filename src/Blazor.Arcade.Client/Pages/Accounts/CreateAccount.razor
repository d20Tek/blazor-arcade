@page "/account/create"
@attribute [Authorize]
@inject ILocalStorageService _storage
@inject IUserProfileClientService _service
@inject NavigationManager _nav;

<h4>New Account</h4>
<p>Create a new account to use in Arcade. This will show you as a different player with a new display name. And allow you to create accounts on different servers.</p>
<hr />

<div class="row">
  <div class="col-12 col-lg-6" style="max-width: 600px">
    <EditForm id="account-form" Model=@_account OnSubmit=@FormSubmitted>
      <DataAnnotationsValidator />
    
      <div class="form-group">
        <label for="account-name">Name:</label>
        <InputText @bind-Value=_account.Name class="form-control" id="account-name"
                   placeholder="Enter display name..." />
        <ValidationMessage For="() => _account.Name"/>
      </div>
      <div class="form-group mt-2">
        <label for="account-server">Select Server:</label>
        <InputSelect @bind-Value=_account.Server class="form-control" id="account-server">
          <option value="s1">s1</option>
        </InputSelect>
        <ValidationMessage For="() => _account.Server"/>
      </div>
      <div class="form-group mt-2">
        <label for="account-gender">Gender:</label>
        <InputSelect @bind-Value=_account.Gender class="form-control" id="account-gender">
          <option value="M">Male</option>
          <option value="F">Female</option>
          <option value="U">Unspecified</option>
        </InputSelect>
        <ValidationMessage For="() => _account.Gender"/>
      </div>
      <div class="form-group my-2">
        <label for="account-avatar">Avatar (coming soon):</label>
        <InputFile @bind-Value=_account.Avatar class="form-control" id="account-avatar"
                   disabled/>
      </div>

      <input type="submit" id="submit-btn" class="btn btn-primary" value="Save" />
      <a class="btn btn-light" href="/accounts/manage">Cancel</a>
    </EditForm>
  </div>
</div>

@code {
    private UserAccount _account = new UserAccount();

    [CascadingParameter]
    public Task<AuthenticationState>? AuthState { get; set; }

    private async Task FormSubmitted(EditContext editContext)
    {
        if (editContext.Validate())
        {
            var result = await _service.CreateEntityAsync(_account);

            var accountKey = await Constants.GetUserAccountKey(AuthState);
            await _storage.SetItemAsync(accountKey, result);

            _nav.NavigateTo("/accounts/manage");
        }
    }
}
