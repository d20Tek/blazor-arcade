@page "/diagnostics"
@attribute [Authorize]

<PageTitle>Arcade - Diagnostics</PageTitle>
<h3>Diagnostics</h3>
<hr />

<AuthorizeView>
    <Authorized>
        <h4>Authenticated User:</h4>
        <hr />
        <div>Name: @context.User.Identity?.Name</div>
        @foreach (var claim in context.User.Claims)
        {
            <div>@claim.ToString()</div>
        }
        <hr />
    </Authorized>
    <NotAuthorized>
        <h4>Authenticated User:</h4>
        <hr />
        <p>User not logged in.</p>
        <hr />
    </NotAuthorized>
</AuthorizeView>

<h4>Arcade Service Diagnostics:</h4>
<hr />

@code {

}
