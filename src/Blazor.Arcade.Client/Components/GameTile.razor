<div class="nav-item px-3">
    <NavLink class="nav-link" href="@GameDetailsUrl" Match="NavLinkMatch.All">
        <img class="game-tile" src="@GameMetadata?.Locations.IconUrl" />
        <span class="game-tile-title">@GameMetadata?.Name</span>
    </NavLink>
</div>

@code {
    private string GameDetailsUrl => $"/games/details/{GameMetadata?.Id}";

    [Parameter]
    public GameMetadata? GameMetadata { get; set; }
}
